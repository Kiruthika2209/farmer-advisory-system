# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Single model (optional). If unset, the server uses a built-in list of free models.
# If set, that model is tried first, then built-in fallbacks (so an outdated slug in .env does not break the app).
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Or set several comma-separated models to try in order (still followed by built-in fallbacks if needed):
# OPENROUTER_MODELS=meta-llama/llama-3.1-8b-instruct:free,meta-llama/llama-3.2-3b-instruct:free

# Photo analysis uses VISION models only (separate from text OPENROUTER_MODEL above):
# OPENROUTER_VISION_MODELS=openrouter/free,google/gemma-3-12b-it:free
# Do NOT use text-only slugs like meta-llama/llama-3-8b-instruct:free for photos — they cause 404 errors.
# MAX_IMAGE_BYTES=6291456

# Optional: request timeout in ms (default 55000 for slow free models)
# OPENROUTER_TIMEOUT_MS=55000

# Optional: paid fallback when free OpenRouter is rate-limited (reliable AI answers)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_MS=60000

# Optional - used for OpenRouter rankings (safe to leave as default for local dev)
# OPENROUTER_SITE_URL=http://localhost:5173
# OPENROUTER_APP_NAME=Farmer Advisory System

# Optional: VoiceRSS API key for Tamil text-to-speech (get free key at https://www.voicerss.org/)
# VOICERSS_API_KEY=

PORT=5000
